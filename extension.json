{
	"name": "AccessibilityToolbar",
	"version": "0.3.1",
	"author": [
		"Dror S. [FFS] ([http://www.kolzchut.org.il Kol-Zchut])"
	],
	"url": "https://github.com/kolzchut/mediawiki-extensions-AccessibilityToolbar",
	"namemsg": "accessibilityToolbar",
	"descriptionmsg": "accessibilityToolbar-desc",
	"license-name": "GPL-2.0+",
	"type": "other",
	"manifest_version": 2,
	"MessagesDirs": {
		"AccessibilityToolbar": [
			"i18n"
		]
	},
	"AutoloadNamespaces": {
		"MediaWiki\\Extension\\AccessibilityToolbar\\": "includes/"
	},
	"HookHandlers": {
		"main": {
			"class": "MediaWiki\\Extension\\AccessibilityToolbar\\Hooks",
			"services": [
				"MainConfig",
				"TitleFactory"
			]
		}
	},
	"config": {
		"AccessibilityToolbarPosition": {
			"value": "top"
		},
		"AccessibilityToolbarIconColor": {
			"value": null
		},
		"AccessibilityToolbarDisableButton": {
			"value": false
		}
	},
	"ResourceModules": {
		"ext.accessibilityToolbar": {
			"scripts": [
				"resources/ext.accessibilityToolbar.js"
			],
			"styles": [
				"resources/ext.accessibilityToolbar.less"
			],
			"dependencies": [
				"mediawiki.cookie"
			],
			"targets": [
				"desktop"
			]
		}
	},
	"ResourceFileModulePaths": {
		"localBasePath": "",
		"remoteExtPath": "AccessibilityToolbar"
	},
	"Hooks": {
		"BeforePageDisplay": "main",
		"SkinAfterBottomScripts": "main"
	}
}
